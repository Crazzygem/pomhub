---
import Layout from "../../layouts/Layout.astro";
import VideoPlayer from "../../components/VideoPlayer.astro";
import VideoInfo from "../../components/VideoInfo.astro";
import RelatedVideos from "../../components/RelatedVideos.astro";
import Comments from "../../components/Comments.astro";
import { db } from "../../db/client";
import { courses, comments } from "../../db/schema";
import { eq, ne, and, desc, isNotNull } from "drizzle-orm";

export const prerender = false;

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/");
}

const course = db.select().from(courses).where(eq(courses.youtubeId, id)).get();

if (!course) {
  return Astro.redirect("/");
}

// Fetch related videos (same category, excluding current)
const relatedVideos = course.category
  ? db.select().from(courses)
      .where(and(eq(courses.category, course.category), ne(courses.youtubeId, id)))
      .limit(10)
      .all()
  : [];

// Fetch other courses for sidebar — prefer synced courses, newest first
const otherCourses = db.select().from(courses)
  .where(and(
    ne(courses.youtubeId, id),
    isNotNull(courses.thumbnailUrl),
  ))
  .orderBy(desc(courses.id))
  .limit(10)
  .all();

// Combine: related first, then fill with others (deduplicate)
const sidebarVideos = [...relatedVideos];
for (const c of otherCourses) {
  if (!sidebarVideos.find(v => v.youtubeId === c.youtubeId)) {
    sidebarVideos.push(c);
  }
}

// Below-fold: "Continue Learning" — random courses from different categories
const continueLearning = db.select().from(courses)
  .where(and(
    ne(courses.youtubeId, id),
    isNotNull(courses.thumbnailUrl),
  ))
  .orderBy(desc(courses.id))
  .limit(12)
  .all();

// Fetch comments for this video
const courseComments = db.select()
  .from(comments)
  .where(eq(comments.youtubeId, id))
  .all();

// View count display
const viewCount = course.viewCount ?? 0;

// Better meta description with real data
const description = `Watch ${course.title} by ${course.channel}. ${course.duration} tutorial with ${viewCount.toLocaleString()} views. Free ${course.category || 'coding'} course on PomHub Dev.`;

// OG image
const ogImage = course.thumbnailUrl || `https://img.youtube.com/vi/${id}/maxresdefault.jpg`;

// Convert "MM:SS" or "HH:MM:SS" duration to ISO 8601 (PT##M##S)
function toIsoDuration(dur: string): string | null {
  const parts = dur.split(":").map(Number);
  if (parts.length === 2) {
    const [m, s] = parts;
    if (isNaN(m) || isNaN(s)) return null;
    return `PT${m}M${s}S`;
  }
  if (parts.length === 3) {
    const [h, m, s] = parts;
    if (isNaN(h) || isNaN(m) || isNaN(s)) return null;
    return `PT${h}H${m}M${s}S`;
  }
  return null;
}
const isoDuration = toIsoDuration(course.duration ?? "");

// URL-encode the category for breadcrumb linking
const encodedCategory = course.category ? encodeURIComponent(course.category) : null;

// Build description for structured data (plain text, no markdown)
const structuredDescription = `${course.title} — a free ${course.duration} coding tutorial by ${course.channel}. ${viewCount.toLocaleString()} views on PomHub Dev.`;
---

<Layout
  title={`${course.title} | PomHub Dev`}
  description={description}
  ogImage={ogImage}
  ogType="video.other"
>
  <!-- OG video tags (Astro hoists meta tags into <head>) -->
  <meta property="og:video" content={`https://www.youtube.com/embed/${id}`} />
  <meta property="og:video:width" content="1280" />
  <meta property="og:video:height" content="720" />

  <!-- VideoObject Structured Data (JSON-LD) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "VideoObject",
    "name": course.title,
    "description": structuredDescription,
    "thumbnailUrl": course.thumbnailUrl || `https://img.youtube.com/vi/${id}/maxresdefault.jpg`,
    "uploadDate": course.createdAt ?? undefined,
    ...(isoDuration && { duration: isoDuration }),
    "embedUrl": `https://www.youtube.com/embed/${id}`,
    "interactionStatistic": [
      {
        "@type": "InteractionCounter",
        "interactionType": { "@type": "WatchAction" },
        "userInteractionCount": viewCount,
      },
    ],
  })} />

  <!-- BreadcrumbList Structured Data (JSON-LD) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://pomhub.site/" },
      ...(course.category
        ? [{ "@type": "ListItem", "position": 2, "name": course.category, "item": `https://pomhub.site/?category=${encodedCategory}` }]
        : []),
      { "@type": "ListItem", "position": course.category ? 3 : 2, "name": course.title },
    ],
  })} />

  <main class="max-w-[1280px] mx-auto px-5 py-4">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-1.5 text-xs mb-4 flex-wrap">
      <a href="/" class="text-text-muted hover:text-accent-primary transition-colors duration-200">Home</a>
      <span class="text-text-dim">&rsaquo;</span>
      {course.category && (
        <>
          <span class="text-accent-primary font-bold">{course.category}</span>
          <span class="text-text-dim">&rsaquo;</span>
        </>
      )}
      <span class="text-text-secondary line-clamp-1">{course.title}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_360px] gap-5">

      <!-- Left Column — Video + Info + Comments -->
      <div class="min-w-0">
        <VideoPlayer youtubeId={course.youtubeId} />
        <VideoInfo
          title={course.title}
          channel={course.channel ?? ""}
          duration={course.duration ?? ""}
          viewCount={viewCount}
          description={description}
          category={course.category ?? undefined}
          createdAt={course.createdAt ?? undefined}
        />
        <Comments comments={courseComments} />
      </div>

      <!-- Right Column — Sidebar -->
      <aside class="min-w-0">
        <RelatedVideos videos={sidebarVideos} />
      </aside>

    </div>

    {/* ── Continue Learning (below fold) ────────── */}
    {continueLearning.length > 0 && (
      <section class="mt-8 border-t border-bg-border pt-6">
        <div class="flex items-baseline justify-between mb-4">
          <div>
            <h2 class="text-sm font-bold text-text-primary uppercase tracking-wide">
              Continue Learning
            </h2>
            <p class="text-xs text-text-muted mt-0.5">
              More courses from PomHub Dev to build your skills
            </p>
          </div>
          <a href="/" class="text-xs font-bold text-accent-primary hover:underline">
            Browse all courses &rarr;
          </a>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-3">
          {continueLearning.map((video) => (
            <a
              href={`/video/${video.youtubeId}`}
              class="group block"
            >
              <div class="relative aspect-video rounded overflow-hidden bg-bg-surface-1 mb-1.5 transition-all duration-300 group-hover:scale-[1.03] group-hover:shadow-md group-hover:shadow-black/40 group-hover:z-10">
                <img
                  src={video.thumbnailUrl || `https://img.youtube.com/vi/${video.youtubeId}/mqdefault.jpg`}
                  alt={video.title}
                  class="w-full h-full object-cover transition-all duration-300 group-hover:brightness-75"
                  loading="lazy"
                />
                <span class="absolute bottom-0.5 right-0.5 text-[10px] text-text-primary bg-black/75 px-1 py-0.5 rounded">
                  {video.duration}
                </span>
                <!-- Play button overlay -->
                <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                  <div class="w-10 h-10 rounded-full bg-accent-primary/90 flex items-center justify-center shadow-lg shadow-black/50">
                    <span class="text-accent-cta-text text-sm ml-0.5">&#9654;</span>
                  </div>
                </div>
              </div>
              <p class="text-xs text-text-secondary leading-tight line-clamp-2 group-hover:text-text-primary transition-colors duration-200">
                {video.title}
              </p>
              <p class="text-[10px] text-text-muted mt-0.5">{video.channel}</p>
              {video.category && (
                <span class="text-[9px] text-accent-primary mt-0.5 inline-block">
                  {video.category}
                </span>
              )}
            </a>
          ))}
        </div>
      </section>
    )}

  </main>
</Layout>
