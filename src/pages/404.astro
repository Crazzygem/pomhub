---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page Not Found | PomHub Dev">
  <main class="max-w-[1280px] mx-auto px-5 py-16 text-center">
    <div class="max-w-md mx-auto">
      <!-- 404 graphic -->
      <div class="text-8xl font-black text-accent-primary mb-4 select-none">
        404
      </div>

      <h1 class="text-xl font-bold text-text-primary mb-2">
        Page Not Found
      </h1>

      <p class="text-sm text-text-muted mb-8 leading-relaxed">
        This video doesn't exist or has been removed.
        Maybe try searching for something else?
      </p>

      <div class="flex items-center justify-center gap-3">
        <a
          href="/"
          class="inline-flex items-center text-sm font-bold text-accent-cta-text bg-accent-primary px-5 py-2.5 rounded-full hover:bg-accent-hover transition-all duration-300 hover:scale-105"
        >
          &larr; Back to Home
        </a>
      </div>
    </div>
  </main>
</Layout>
