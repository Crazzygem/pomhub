---
import Layout from "../layouts/Layout.astro";
import { db } from "../db/client";
import { courses } from "../db/schema";

export const prerender = false;

// Get all categories with counts
const allCourses = db.select().from(courses).all();
const categoryCounts = new Map<string, number>();
for (const c of allCourses) {
  const cat = c.category || "Uncategorized";
  categoryCounts.set(cat, (categoryCounts.get(cat) || 0) + 1);
}
const categories = [...categoryCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<Layout title="Categories | PomHub Dev">
  <main class="max-w-[1280px] mx-auto px-5 py-6">
    <h1 class="text-lg font-bold text-text-primary mb-1">Categories</h1>
    <p class="text-xs text-text-muted mb-6">{allCourses.length} courses across {categories.length} categories</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
      {categories.map(([cat, count]) => (
        <a
          href={`/?category=${encodeURIComponent(cat)}`}
          class="block bg-bg-surface-1 rounded p-4 hover:bg-bg-surface-2 transition-all duration-200 hover:scale-[1.02] group"
        >
          <h2 class="text-sm font-bold text-text-primary group-hover:text-accent-primary transition-colors duration-200">
            {cat}
          </h2>
          <p class="text-xs text-text-muted mt-1">
            {count} {count === 1 ? "course" : "courses"}
          </p>
        </a>
      ))}
    </div>
  </main>
</Layout>
