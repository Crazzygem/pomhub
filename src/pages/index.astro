---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Categories from "../components/Categories.astro";
import CourseGrid from "../components/CourseGrid.astro";
import Testimonials from "../components/Testimonials.astro";
import BottomCta from "../components/BottomCta.astro";

// Import DB client
import { db } from "../db/client";
import { courses } from "../db/schema";

// Fetch all courses and shuffle for dynamic content
const allCourses = db.select().from(courses).all();

// Fisher-Yates shuffle for random mix from all channels
function shuffle<T>(arr: T[]): T[] {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

const shuffled = shuffle(allCourses);

// Get featured course for hero (random synced course)
const syncedCourses = shuffled.filter(c => c.source === "sync");
const featuredCourse = syncedCourses[0] || shuffled[0];

// Get categories from all courses
const categories = [...new Set(
  allCourses.map(c => c.category).filter(Boolean)
)];

// Get 12 random courses for grid
const popularCourses = shuffled.slice(0, 12);
---

<Layout>
  <main class="max-w-[1280px] mx-auto px-5">
    <Hero course={featuredCourse} />
    <Categories {categories} />
    <CourseGrid courses={popularCourses} />
    <Testimonials />
    <BottomCta />
  </main>
</Layout>
