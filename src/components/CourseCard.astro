---
// Course Card — single course item
export interface Props {
  youtubeId: string;
  title: string;
  channel: string;
  duration: string;
  category?: string | null;
  thumbnailUrl?: string | null;
  delay?: number;
}

const { youtubeId, title, channel, duration, category, thumbnailUrl, delay = 0 } = Astro.props;

// Use thumbnailUrl if provided, otherwise construct from youtubeId
const thumb = thumbnailUrl || `https://img.youtube.com/vi/${youtubeId}/mqdefault.jpg`;
---

<article
  class="flex flex-col px-1.5 py-1 group animate-fade-in-up overflow-hidden"
  style={`animation-delay: ${delay}ms`}
>
  <!-- Thumbnail with button-like hover popout -->
  <a
    href={`/video/${youtubeId}`}
    class="relative w-full aspect-video rounded-sm overflow-hidden mb-1.5 transition-all duration-300 group-hover:scale-[1.03] group-hover:shadow-lg group-hover:shadow-black/40 group-hover:z-10"
  >
    <img
      src={thumb}
      alt={title}
      class="w-full h-full object-cover transition-all duration-300 group-hover:brightness-75"
      loading="lazy"
    />
    <!-- Duration badge -->
    <span class="absolute bottom-1 right-1 text-xs text-text-primary bg-black/80 px-1 py-0.5 rounded-sm font-medium">
      {duration}
    </span>
    <!-- Play button overlay (appears on hover) -->
    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
      <div class="w-10 h-10 rounded-full bg-accent-primary/90 flex items-center justify-center shadow-lg shadow-black/50">
        <span class="text-accent-cta-text text-sm ml-0.5">&#9654;</span>
      </div>
    </div>
  </a>

  <!-- Title -->
  <a
    href={`/video/${youtubeId}`}
    class="text-sm text-text-secondary leading-tight mb-0.5 line-clamp-2 hover:text-text-primary transition-colors duration-200"
  >
    {title}
  </a>

  <!-- Channel -->
  <a
    href="#"
    class="text-xs text-text-link hover:text-accent-hover transition-colors duration-200"
  >
    {channel}
  </a>
</article>
