---
// Main Header — single clean bar matching Pornhub-style layout
const navItems = [
  { label: "Home", href: "/" },
  { label: "Categories", href: "/categories" },
  { label: "Channels", href: "/channels" },
  { label: "Community", href: "/community" },
];
---

<header class="flex flex-wrap items-center px-5 py-2 border-b border-bg-border gap-x-4 gap-y-2">
  <!-- Logo — Pornhub-style: Pom (white text, no bg) + Hub (black text on orange pill) -->
  <a href="/" class="flex items-center whitespace-nowrap select-none">
    <span class="text-white font-black text-[22px] tracking-tight leading-none">
      Pom
    </span>
    <span class="bg-accent-primary text-black font-black text-[22px] px-1 py-0.5 rounded-[3px] tracking-tight leading-none ml-[1px]">
      hub
    </span>
    <span class="text-[15px] font-bold text-text-muted ml-2 leading-none self-start mt-0.1">
      Dev
    </span>
  </a>

  <!-- Main nav (hidden on mobile, visible md+) -->
  <nav class="hidden md:flex gap-0.5 w-auto">
    {navItems.map((item) => (
      <a
        href={item.href}
        class="text-xs font-bold text-text-secondary hover:text-accent-hover uppercase px-2.5 py-1 transition-colors duration-200"
      >
        {item.label}
      </a>
    ))}
  </nav>

  <!-- Mobile hamburger (visible only on mobile) -->
  <button class="md:hidden flex items-center justify-center w-8 h-8 text-text-secondary hover:text-text-primary transition-colors duration-200 ml-auto" aria-label="Menu">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
    </svg>
  </button>

  <!-- Search (visible on all screens) -->
  <div class="flex items-center ml-auto md:ml-0 order-last md:order-none w-full md:w-auto mt-2 md:mt-0">
    <form action="/" method="GET" class="flex items-center w-full md:w-auto" role="search">
      <input
        type="search"
        name="q"
        placeholder="Search courses..."
        aria-label="Search courses"
        class="bg-bg-surface-3 text-text-primary text-sm h-[37px] px-3 border-none rounded-[20px] outline-none w-full md:w-[220px] placeholder:text-text-dim transition-all duration-300 md:focus:w-[280px]"
      />
    </form>
  </div>

  <!-- Desktop auth buttons (hidden on mobile, visible md+) -->
  <div class="hidden md:flex items-center gap-2 flex-shrink-0">
    <a
      href="#"
      class="text-xs text-text-primary px-2 whitespace-nowrap hover:text-accent-hover transition-colors duration-200"
      onclick="event.preventDefault(); alert('Log In — coming soon!')"
    >
      Log In
    </a>

    <a
      href="#"
      class="inline-flex items-center text-xs font-bold text-accent-cta-text bg-accent-cta px-3.5 py-1.5 border-2 border-accent-cta-text rounded-[20px] h-[38px] whitespace-nowrap hover:bg-accent-primary transition-all duration-300 hover:scale-105 active:scale-95"
      onclick="event.preventDefault(); alert('Sign Up — coming soon!')"
    >
      Sign Up
    </a>
  </div>
</header>
