---
// Pagination
const pages = [1, 2, 3, 4, 5, "...", 10];
---

<div class="flex items-center justify-center gap-1 my-5 animate-fade-in-up delay-300">
  <a
    href="#"
    class="text-xs text-text-secondary px-2 py-1 hover:text-accent-hover transition-colors duration-200"
  >
    Prev
  </a>

  {pages.map((page) =>
    page === "..." ? (
      <span class="text-xs text-text-muted px-1">...</span>
    ) : (
      <a
        href="#"
        class="text-xl text-accent-cta-text bg-accent-primary px-3 py-1 rounded-sm leading-tight transition-all duration-200 hover:bg-accent-hover hover:scale-105"
        class:list={{ "cursor-default": page === 1 }}
      >
        {page}
      </a>
    )
  )}

  <a
    href="#"
    class="text-xs text-text-secondary px-2 py-1 hover:text-accent-hover transition-colors duration-200"
  >
    Next
  </a>
</div>
