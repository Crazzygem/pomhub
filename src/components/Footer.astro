---
// Footer — minimal 2-column layout

interface FooterGroup {
  title: string;
  links: { label: string; href: string }[];
}

const groups: FooterGroup[] = [
  {
    title: "Platform",
    links: [
      { label: "All Courses", href: "/" },
      { label: "Learning Paths", href: "#" },
      { label: "Pricing", href: "#" },
      { label: "For Teams", href: "#" },
      { label: "Free Courses", href: "#" },
    ],
  },
  {
    title: "Legal",
    links: [
      { label: "Terms of Service", href: "#" },
      { label: "Privacy Notice", href: "#" },
      { label: "DMCA", href: "#" },
      { label: "Cookie Notice", href: "#" },
    ],
  },
];
---

<footer class="border-t border-bg-border px-5 pt-5 pb-6 mt-6">
  <!-- Link groups -->
  <div class="grid grid-cols-2 gap-6 max-w-[1280px] mx-auto">
    {groups.map((group) => (
      <div>
        <h4 class="text-[13px] font-bold text-[#cccccc] uppercase mb-2.5">
          {group.title}
        </h4>
        <ul class="flex flex-col gap-1">
          {group.links.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-xs text-text-muted hover:text-accent-hover transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <!-- Copyright -->
  <div class="max-w-[1280px] mx-auto mt-4 pt-3 border-t border-bg-border text-xs text-text-dim text-center">
    <span>&copy; 2026 PomHub Dev. All rights reserved.</span>
  </div>
</footer>
