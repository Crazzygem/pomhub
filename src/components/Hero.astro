---
// Hero Section — featured course
export interface Props {
  course?: {
    youtubeId: string;
    title: string;
    channel: string;
    duration: string;
    viewCount: number;
    thumbnailUrl?: string;
  };
}

const { course } = Astro.props;

// Get thumbnail URL (use provided or construct from youtubeId)
const thumbnailUrl = course?.thumbnailUrl || (course?.youtubeId ? `https://img.youtube.com/vi/${course.youtubeId}/maxresdefault.jpg` : null);

// Format view count
const formatViewCount = (count: number) => {
  if (count >= 1000000) return `${(count / 1000000).toFixed(1)}M`;
  if (count >= 1000) return `${(count / 1000).toFixed(1)}k`;
  return count.toString();
};
---

<section class="grid grid-cols-1 md:grid-cols-2 gap-6 bg-bg-surface-1 rounded overflow-hidden mt-4 animate-fade-in-up">
  <!-- Thumbnail -->
  <div class="aspect-video bg-gradient-to-br from-[#1a1a2e] via-[#16213e] to-[#0f3460] flex items-center justify-center relative group overflow-hidden">
    {thumbnailUrl ? (
      <img 
        src={thumbnailUrl} 
        alt={course?.title || "Featured Course"} 
        class="absolute inset-0 w-full h-full object-cover"
      />
    ) : (
      <div class="absolute inset-0 bg-gradient-to-br from-[#1a1a2e] via-[#16213e] to-[#0f3460]" />
    )}
    <a 
      href={course?.youtubeId ? `/video/${course.youtubeId}` : "#"}
      class="relative z-10 w-16 h-16 rounded-full bg-accent-primary/90 flex items-center justify-center cursor-pointer transition-all duration-300 group-hover:scale-110 group-hover:bg-accent-primary animate-glow-pulse"
    >
      <span class="text-accent-cta-text text-2xl ml-0.5">&#9654;</span>
    </a>
  </div>

  <!-- Content -->
  <div class="p-6 md:pl-0 md:pr-6 flex flex-col justify-center gap-2.5 animate-fade-in-up delay-200">
    <span class="text-[11px] font-bold text-accent-primary uppercase tracking-wider">
      Featured Course
    </span>

    <h1 class="text-[22px] font-bold text-text-primary leading-tight">
      {course?.title || "Full-Stack Web Development Bootcamp"}
    </h1>

    <p class="text-sm text-text-muted">
      {course?.duration || "42 hours"} &middot; 12 modules &middot; 120+ exercises
    </p>

    <a href="#" class="text-sm text-text-link hover:text-accent-hover transition-colors duration-200">
      {course?.channel || "John Doe"}
    </a>

    <p class="text-sm text-text-muted" style="margin:0">
      &#9733; 4.8 &middot; {course?.viewCount ? `${formatViewCount(course.viewCount)} views` : "2,340 students"}
    </p>

    <div class="flex gap-3 mt-1">
      <a
        href={course?.youtubeId ? `/video/${course.youtubeId}` : "#"}
        class="inline-flex items-center text-sm font-bold text-accent-primary bg-transparent px-4 py-1.5 border-2 border-accent-primary rounded-[20px] h-[38px] hover:bg-accent-primary hover:text-accent-cta-text transition-all duration-300 hover:scale-105 active:scale-95"
      >
        &#9654; Watch Trailer
      </a>
      <a
        href="#"
        class="inline-flex items-center text-sm font-bold text-accent-cta-text bg-accent-cta px-4 py-1.5 border-2 border-accent-cta-text rounded-[20px] h-[38px] hover:bg-accent-primary transition-all duration-300 hover:scale-105 active:scale-95"
      >
        Enroll Now — $199
      </a>
    </div>
  </div>
</section>
