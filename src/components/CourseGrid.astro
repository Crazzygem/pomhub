---
// Course Grid — Popular Courses section with pagination
import CourseCard from "./CourseCard.astro";
import Pagination from "./Pagination.astro";

export interface Props {
  courses: {
    youtubeId: string;
    title: string;
    channel: string;
    duration: string;
    category?: string | null;
    thumbnailUrl?: string | null;
  }[];
  currentPage?: number;
  totalPages?: number;
}

const { courses, currentPage = 1, totalPages = 1 } = Astro.props;
---

<section>
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-y-3 gap-x-1">
    {courses.map((course, i) => (
      <CourseCard {...course} delay={i * 30} />
    ))}
  </div>

  {totalPages > 1 && (
    <Pagination {currentPage} {totalPages} />
  )}
</section>
