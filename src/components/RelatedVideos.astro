---
export interface Video {
  youtubeId: string;
  title: string;
  channel: string;
  duration: string;
  thumbnailUrl?: string;
}

export interface Props {
  videos: Video[];
}

const { videos } = Astro.props;
const initialCount = 10;
const hasMore = videos.length > initialCount;
---

<div class="space-y-4">

  <!-- Related Videos -->
  <div>
    <h3 class="text-sm font-bold text-text-primary mb-2 uppercase tracking-wide">
      Related Videos
    </h3>
    <div class="sidebar-list space-y-2">
      {videos.map((video, index) => (
        <a
          href={`/video/${video.youtubeId}`}
          class={`flex gap-2 group animate-fade-in-up ${index >= initialCount ? 'hidden' : ''}`}
          data-index={index}
        >
          <div class="relative w-[160px] h-[90px] flex-shrink-0 rounded overflow-hidden bg-bg-surface-1 transition-all duration-300 group-hover:scale-[1.03] group-hover:shadow-md group-hover:shadow-black/40 group-hover:z-10">
            <img
              src={video.thumbnailUrl || `https://img.youtube.com/vi/${video.youtubeId}/mqdefault.jpg`}
              alt={video.title}
              class="w-full h-full object-cover transition-all duration-300 group-hover:brightness-75"
              loading="lazy"
            />
            <span class="absolute bottom-0.5 right-0.5 text-[10px] text-text-primary bg-black/75 px-1 py-0.5 rounded">
              {video.duration}
            </span>
            <!-- Play button overlay -->
            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="w-8 h-8 rounded-full bg-accent-primary/90 flex items-center justify-center shadow-lg shadow-black/50">
                <span class="text-accent-cta-text text-xs ml-0.5">&#9654;</span>
              </div>
            </div>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-xs text-text-secondary leading-tight line-clamp-2 group-hover:text-text-primary transition-colors duration-200">
              {video.title}
            </p>
            <p class="text-[10px] text-text-muted mt-0.5">{video.channel}</p>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- Show more -->
  {hasMore && (
    <button class="sidebar-show-more w-full py-2 text-xs font-bold text-text-secondary bg-bg-surface-1 rounded hover:bg-bg-surface-2 transition-colors duration-200">
      Show more
    </button>
  )}

</div>

<script is:inline>
  document.querySelectorAll('.sidebar-show-more').forEach(btn => {
    btn.addEventListener('click', function() {
      var list = this.closest('.space-y-4').querySelector('.sidebar-list');
      var hidden = list.querySelectorAll('a.hidden');
      hidden.forEach(function(item) {
        item.classList.remove('hidden');
      });
      this.style.display = 'none';
    });
  });
</script>
