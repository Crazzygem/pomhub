---
export interface Video {
  youtubeId: string;
  title: string;
  channel: string;
  duration: string;
  thumbnailUrl?: string;
}

export interface Props {
  videos: Video[];
  courses: Video[];
}

const { videos, courses } = Astro.props;
const totalVideos = videos.length + courses.length;
---

<div class="space-y-4">

  <!-- Up Next -->
  <div class="mb-4">
    <div class="flex items-center justify-between mb-2">
      <h3 class="text-sm font-bold text-text-primary uppercase tracking-wide">
        Up Next
      </h3>
      <!-- Autoplay toggle (cosmetic) -->
      <label class="flex items-center gap-1.5 cursor-pointer select-none">
        <span class="text-[10px] text-text-dim">Autoplay</span>
        <div class="relative w-8 h-4 rounded-full bg-bg-surface-3 transition-colors duration-200 hover:bg-bg-surface-5">
          <div class="absolute left-0.5 top-0.5 w-3 h-3 rounded-full bg-text-dim transition-all duration-200"></div>
        </div>
      </label>
    </div>
    <div class="sidebar-list space-y-2">
      {videos.map((video) => (
        <a
          href={`/video/${video.youtubeId}`}
          class="flex gap-2 group animate-fade-in-up"
        >
          <div class="relative w-[160px] h-[90px] flex-shrink-0 rounded overflow-hidden bg-bg-surface-1">
            <img
              src={video.thumbnailUrl || `https://img.youtube.com/vi/${video.youtubeId}/mqdefault.jpg`}
              alt={video.title}
              class="w-full h-full object-cover transition-all duration-300 group-hover:brightness-75 group-hover:scale-105"
              loading="lazy"
            />
            <span class="absolute bottom-0.5 right-0.5 text-[10px] text-text-primary bg-black/75 px-1 py-0.5 rounded">
              {video.duration}
            </span>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-xs text-text-secondary leading-tight line-clamp-2 group-hover:text-text-primary transition-colors duration-200">
              {video.title}
            </p>
            <p class="text-[10px] text-text-muted mt-0.5">{video.channel}</p>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- Related Courses -->
  <div class="border-t border-bg-border pt-3">
    <h3 class="text-sm font-bold text-text-primary mb-2 uppercase tracking-wide">
      Related Courses
    </h3>
    <div class="sidebar-list space-y-2">
      {courses.map((course) => (
        <a
          href={`/video/${course.youtubeId}`}
          class="flex gap-2 group animate-fade-in-up"
        >
          <div class="relative w-[160px] h-[90px] flex-shrink-0 rounded overflow-hidden bg-bg-surface-1">
            <img
              src={course.thumbnailUrl || `https://img.youtube.com/vi/${course.youtubeId}/mqdefault.jpg`}
              alt={course.title}
              class="w-full h-full object-cover transition-all duration-300 group-hover:brightness-75 group-hover:scale-105"
              loading="lazy"
            />
            <span class="absolute bottom-0.5 right-0.5 text-[10px] text-text-primary bg-black/75 px-1 py-0.5 rounded">
              {course.duration}
            </span>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-xs text-text-secondary leading-tight line-clamp-2 group-hover:text-text-primary transition-colors duration-200">
              {course.title}
            </p>
            <p class="text-[10px] text-text-muted mt-0.5">{course.channel}</p>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- Show more (if more than 5 up next) -->
  {videos.length > 5 && (
    <button class="sidebar-show-more w-full py-2 text-xs font-bold text-text-secondary bg-bg-surface-1 rounded hover:bg-bg-surface-2 transition-colors duration-200">
      Show {videos.length - 5} more
    </button>
  )}

</div>
