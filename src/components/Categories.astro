---
// Categories — pill row
export interface Props {
  categories?: string[];
}

const { categories = [
  "Web Development",
  "Data Science",
  "Python",
  "Machine Learning",
  "DevOps",
  "Mobile Development",
  "UI/UX Design",
  "Cybersecurity",
] } = Astro.props;
---

<section class="animate-fade-in-up delay-100">
  <h2 class="text-base font-bold text-text-primary capitalize mb-3 pb-2 border-b border-bg-border">
    Categories
  </h2>

  <div class="flex flex-wrap gap-2 mb-2">
    {categories.map((cat) => (
      <a
        href="#"
        class="inline-block text-sm text-text-primary bg-bg-surface-1 px-[18px] py-2 rounded-[8px] hover:bg-bg-surface-5 transition-all duration-200 hover:scale-105"
      >
        {cat}
      </a>
    ))}
  </div>
</section>
