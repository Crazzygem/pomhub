---
// Network Bar — top sub-brand bar
const links = [
  "SpiceEDU",
  "DevRise",
  "CodeMarket",
  "TechBlog",
  "Shop",
  "Trust & Safety",
];
---

<nav class="flex items-center justify-between h-8 px-5 border-b border-bg-border text-text-secondary text-xs font-bold">
  <div class="flex gap-4">
    {links.map((link) => (
      <a href="#" class="text-text-secondary hover:text-accent-hover transition-colors duration-200">
        {link}
      </a>
    ))}
  </div>
  <span class="text-text-dim font-normal text-[11px] cursor-pointer">English</span>
</nav>
