---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import AgeVerification from "../components/AgeVerification.astro";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "PomHub Dev — Coding Bootcamp",
  description = "Free coding courses, tutorials, and bootcamps. Learn networking, Python, Linux, Docker, and more from top creators.",
  ogImage,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || "http://localhost:4321");
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="PomHub Dev" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}
    <meta property="og:url" content={canonicalURL} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
  </head>
  <body class="flex flex-col min-h-screen">
    <Header />
    <div class="flex-1">
      <slot />
    </div>
    <Footer />
    <AgeVerification />
  </body>
</html>
